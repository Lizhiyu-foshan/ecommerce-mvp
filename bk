# 主逻辑
case "$COMMAND" in
    analyst)
        run_analyst
        ;;
    ux-wireframe)
        run_ux_wireframe "$@"
        ;;
    pm)
        run_pm
        ;;
    architect)
        run_architect
        ;;
    ux-visual)
        run_ux_visual
        ;;
    frontend)
        run_frontend
        ;;
    backend)
        run_backend
        ;;
    qa)
        run_qa
        ;;
    full)
        run_full
        ;;
    quick)
        run_quick
        ;;
    help|--help|-h)
        show_help
        ;;
    version|--version|-v)
        show_version
        ;;
    *)
        echo "❌ 未知命令: $COMMAND"
        show_help
        exit 1
        ;;
esac
